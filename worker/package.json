{
  "name": "engedlru-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute engedlru-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute engedlru-db --remote --file=./schema.sql",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "vitest": "^4.1.10",
    "wrangler": "^3.90.0"
  }
}
